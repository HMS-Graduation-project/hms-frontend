# ──────────────────────────────────────
# HMS Frontend - Local Development
# Copy to .env: cp .env.example .env
# When running via docker-compose, env is injected from hms-infra/.env
# ──────────────────────────────────────

# API base URL
# - With Docker (via nginx):  /api
# - Local dev (no Docker):    http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000/api
